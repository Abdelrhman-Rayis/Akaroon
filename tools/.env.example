# Akaroon OCR Pipeline — environment variables
# Copy this file to tools/.env and fill in values.
# tools/.env is gitignored — never commit real credentials.

# ── Mistral ───────────────────────────────────────────────────
MISTRAL_API_KEY=your-mistral-api-key-here

# ── Cloud SQL (MySQL) ─────────────────────────────────────────
# Direct TCP from Mac often times out — run inside Docker instead:
#   docker exec -it akaroon_php python3 /var/www/html/tools/ocr_pipeline.py
DB_HOST=34.76.91.107
DB_PORT=3306
DB_USER=akaroon
DB_PASSWORD=your-db-password-here
DB_NAME=akaroon_akaroondb

# ── Google Cloud Storage ──────────────────────────────────────
# Auth option 1 (recommended for local use):
#   gcloud auth application-default login
#
# Auth option 2 (service account key file):
#   GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
#
# Leave blank if using gcloud ADC (option 1):
# GOOGLE_APPLICATION_CREDENTIALS=
