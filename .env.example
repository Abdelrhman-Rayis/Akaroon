# ─── Akaroon environment variables ──────────────────────────────────────────
# Copy this to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Local Docker (docker-compose) ────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_strong_password
PMA_PASSWORD=change_me_strong_password
INSERT_ADMIN_PASSWORD_HASH=   # php -r "echo password_hash('yourpassword', PASSWORD_BCRYPT);"

# ── Shared DB config (used by PHP app via getenv()) ──────────────────────────
DB_HOST=mysql                     # 'mysql' for Docker Compose; '127.0.0.1' for Cloud Run TCP
DB_SOCKET=                        # Cloud Run only: /cloudsql/PROJECT:REGION:INSTANCE
DB_NAME=akaroon_akaroondb
DB_USER=root                      # use a dedicated user in production
DB_PASSWORD=change_me_strong_password

# ── WordPress databases ───────────────────────────────────────────────────────
WP_BLOG_DB_NAME=akaroon_a-wordp-1gu      # local name
WP_LIBRARY_DB_NAME=akaroon_a-wordp-qxn  # local name

# ── WordPress URLs ────────────────────────────────────────────────────────────
WP_URL=http://localhost:8082     # set to your Cloud Run URL in production

# ── WordPress auth keys (generate at https://api.wordpress.org/secret-key/1.1/salt/) ──
WP_AUTH_KEY=
WP_SECURE_AUTH_KEY=
WP_LOGGED_IN_KEY=
WP_NONCE_KEY=
WP_AUTH_SALT=
WP_SECURE_AUTH_SALT=
WP_LOGGED_IN_SALT=
WP_NONCE_SALT=
