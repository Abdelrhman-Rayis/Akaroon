# ─── Akaroon local development environment ─────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

MYSQL_ROOT_PASSWORD=change_me_strong_password
PMA_PASSWORD=change_me_strong_password
INSERT_ADMIN_PASSWORD_HASH=   # generate with: php -r "echo password_hash('yourpassword', PASSWORD_BCRYPT);"
