# ─── Large binary / media files ───────────────────────────────────────────────
# PDFs (36 GB – never commit these)
*.pdf
*.PDF

# Cover images stored alongside PDFs
public_html/files/*/image/
public_html/files/*/files/

# Scanned page images in root
public_html/I.A.O.-page-*.jpg
public_html/*.PNG
public_html/*.jpg
public_html/*.jpeg
public_html/*.gif
public_html/*.png

# ─── WordPress uploads ─────────────────────────────────────────────────────────
public_html/blog/wp-content/uploads/
public_html/library/wp-content/uploads/

# ─── WordPress cache / generated files ────────────────────────────────────────
public_html/blog/wp-content/cache/
public_html/library/wp-content/cache/
public_html/blog/wp-content/litespeed/
public_html/library/wp-content/litespeed/
*.cache

# ─── WordPress sensitive config (originals – Docker overrides are kept) ───────
public_html/blog/wp-config.php
public_html/library/wp-config.php

# ─── Docker runtime / local data ──────────────────────────────────────────────
mysql_data/
docker/mysql-data/

# ─── Arabic Ontology data (Birzeit University copyright — do not distribute) ──
ArabicOntology*/
public_html/lib/ontology_lookup.php

# ─── Qabas data (CC-BY-ND-4.0 — raw CSVs OK to commit; generated lookup is a
#     derivative and must NOT be distributed per the NoDerivatives clause) ────
public_html/lib/qabas_lookup.php

# ─── Server backup archives ───────────────────────────────────────────────────
backup-*
*.tar.gz
*.tar
*.zip

# ─── Server infrastructure directories (from FTP download) ────────────────────
etc/
logs/
lscache/
mail/
ssl/
tmp/
soon
soon.html
public_html1/
IAOL/

# ─── Loose image files in project root ────────────────────────────────────────
*.jpg
*.jpeg
*.png
*.PNG
*.gif
# Exceptions: architecture diagram and screenshots for README/docs
!architecture_diagram.png
!docs/screenshots/*.png
!docs/screenshots/*.jpg
!docs/*.png
!docs/*.jpg
!docs/*.jpeg
# Exceptions: site UI images (professor portrait, homepage photos, etc.)
!public_html/img/

